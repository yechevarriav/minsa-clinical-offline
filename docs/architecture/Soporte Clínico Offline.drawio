  <diagram name="Flujo-de-Datos" id="zNiqUVITHMh2BVSu1gMe">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#1A5276;" value="Flujo de Datos — Request/Response con Contexto Demográfico&lt;br&gt;Sistema de Soporte Clínico Offline" vertex="1">
          <mxGeometry height="60" width="1200" x="227" y="40" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1A5276;fontColor=#1A5276;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(1) MÉDICO&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Ingresa síntomas + edad + sexo&lt;br&gt;en Frontend HTML&lt;br&gt;&lt;br&gt;Ej: &#39;fiebre alta&#39; + 45 años + M" vertex="1">
          <mxGeometry height="140" width="220" x="52" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2980B9;strokeColor=#1A5276;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(2) FASTAPI&lt;/font&gt;&lt;/b&gt;&lt;br&gt;POST /api/v1/query&lt;br&gt;&lt;br&gt;Construye query enriquecida:&lt;br&gt;&#39;fiebre alta (paciente de&lt;br&gt;45 años, sexo masculino)&#39;" vertex="1">
          <mxGeometry height="140" width="220" x="362" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#154360;strokeColor=#0d2b40;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(3) NER EXTRACTOR&lt;br&gt;&lt;/font&gt;&lt;/b&gt;Identifica entidades:&lt;br&gt;&lt;br&gt;[SINTOMA: fiebre_alta]&lt;br&gt;[EDAD: adulto]&lt;br&gt;[SEXO: masculino]&lt;br&gt;13 categorías médicas" vertex="1">
          <mxGeometry height="160" width="220" x="702" y="200" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#154360;strokeColor=#0d2b40;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(5) SEMANTIC ENGINE&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Genera embedding 768d&lt;br&gt;con roberta-base-biomedical-clinical-es&lt;br&gt;&lt;br&gt;~50ms en CPU" vertex="1">
          <mxGeometry height="140" width="220" x="1382" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#154360;strokeColor=#0d2b40;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(6) FAISS INDEX&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Búsqueda similitud&lt;br&gt;en 14,702 vectores CIE-10&lt;br&gt;&lt;br&gt;Top-5 resultados&lt;br&gt;&amp;lt;100ms latencia" vertex="1">
          <mxGeometry height="160" width="220" x="1382" y="460" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2980B9;strokeColor=#1A5276;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&amp;nbsp;(7) FASTAPI&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Retorna JSON:&lt;br&gt;&lt;br&gt;{results: [{code: &#39;R50&#39;,&lt;br&gt;description: &#39;FIEBRE&#39;,&lt;br&gt;score: 0.89},...],&lt;br&gt;search_time_ms: 866}" vertex="1">
          <mxGeometry height="180" width="220" x="1382" y="750" as="geometry" />
        </mxCell>
        <mxCell id="s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1A5276;fontColor=#1A5276;fontSize=12;arcSize=5;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(8) FRONTEND&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Muestra resultados&lt;br&gt;con código + descripción + score&lt;br&gt;&lt;br&gt;Médico selecciona&lt;br&gt;código correcto" vertex="1">
          <mxGeometry height="180" width="220" x="1022" y="750" as="geometry" />
        </mxCell>
        <mxCell id="s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#154360;strokeColor=#0d2b40;fontColor=#ffffff;fontSize=12;arcSize=5;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;(9) FEEDBACK&lt;br&gt;&lt;/b&gt;&lt;/font&gt;POST /api/v1/feedback&lt;br&gt;&lt;br&gt;Guarda en SQLite:&lt;br&gt;• query original&lt;br&gt;• código CIE-10 seleccionado&lt;br&gt;• edad: 45&lt;br&gt;• sexo: M&lt;br&gt;• timestamp" vertex="1">
          <mxGeometry height="200" width="220" x="662" y="740" as="geometry" />
        </mxCell>
        <mxCell id="s9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;arcSize=5;strokeDasharray=5 5;" value="🦙 &lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;LLM OPCIONAL&lt;/font&gt;&lt;/b&gt;&lt;br&gt;(solo modo local)&lt;br&gt;&lt;br&gt;RAGEngine → Ollama&lt;br&gt;Llama-2 7B genera&lt;br&gt;recomendación enriquecida&lt;br&gt;+2-5s latencia adicional" vertex="1">
